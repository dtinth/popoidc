# Public HTTPS issuer URL. Must exactly equal the `iss` claim and be reachable by
# relying parties (e.g. octo-sts). Traefik/Dokploy serves this domain.
SSHID_ISSUER=https://sshid.example

# RSA private signing key, as a JWK with a "kid". Generate one with:
#   deno task keygen
# then paste the single-line JSON here (keep it secret).
SSHID_SIGNING_JWK={"kty":"RSA","n":"...","e":"AQAB","d":"...","p":"...","q":"...","dp":"...","dq":"...","qi":"...","kid":"2026-07-05","alg":"RS256","use":"sig"}

# Secret keying the stateless challenge HMAC. Use a long random string, e.g.
#   openssl rand -base64 48
SSHID_HMAC_SECRET=replace-with-a-long-random-secret

# Optional: SSHSIG namespace bound into Signing Proofs (default: sshid)
# SSHID_NAMESPACE=sshid

# Optional: listen port (default: 8000)
# PORT=8000
